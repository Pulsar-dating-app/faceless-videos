{
  "crons": [
    { "path": "/api/cron/schedule-videos", "schedule": "*/10 * * * *" },
    { "path": "/api/cron/build-occurrences", "schedule": "0 2 * * *" },
    { "path": "/api/cron/reset-generations", "schedule": "0 0 * * 0" },
    { "path": "/api/cron/consume-queue", "schedule": "*/10 * * * *" },
    { "path": "/api/cron/queue-scheduler", "schedule": "*/10 * * * *" },
    { "path": "/api/cron/publish-posts", "schedule": "*/10 * * * *" }
  ],
  "headers": [
    {
      "source": "/videos/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
